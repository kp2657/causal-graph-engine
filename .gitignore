# Secrets — never commit
.env

# Internal development scripts — not part of the supported pipeline
scripts/dev/

# Data and graph databases (too large; download instructions in README)
data/**
*.kuzu
*.h5ad
# Exception: keep validated pipeline output files
# Note: full result JSONs exceed GitHub's 100 MB limit and are excluded.
# Regenerate with: python -m orchestrator.pi_orchestrator_v2 analyze_disease_v2 "<disease>"
!data/analyze_coronary_artery_disease.md
!data/analyze_rheumatoid_arthritis.md
!data/exports/
!data/exports/*.ttl
!data/exports/*.jsonld
!data/exports/*_edges.csv

# Run logs (contain API traces and personal data)
*.log

# Internal development tracking — not part of the public API
STATE.md
CLAUDE.md
CHANGELOG.md
CONTRIBUTING.md
AMD_*.md
dynamical_state_space_redesign_for_claude.md
CHANGELOG_archive.md

# Claude plan files and memory
.claude/

# SDK-only agents (not used in default local pipeline)
agents/cso/
agents/discovery/
agents/*/prompts/
orchestrator/prompts/

# Auxiliary scripts not needed to reproduce results
scripts/analyze_cad_graph.py
scripts/run_tier2_subset.py
scripts/populate_motif_library.py

# Standalone scheduler (not connected to pipeline)
scheduler/

# Python artifacts
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
dist/

# Other
.dvc/
.DS_Store
