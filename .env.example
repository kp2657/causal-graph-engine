# =============================================================================
# REQUIRED to run (AGENT_MODE=sdk only)
# =============================================================================
# Not needed for the default local pipeline (AGENT_MODE=local, the default).
# Only set this if using sdk mode for CSO/discovery-refinement agent reasoning.
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# STRONGLY RECOMMENDED — free, register in <5 min
# =============================================================================

# IEU Open GWAS — JWT token (free; register at https://api.opengwas.io via GitHub OAuth)
# IMPORTANT: expires 14 days after issue; renew before each AMD/CAD run.
# Used for: MR instrument lookup (CAD: ieu-a-7, ieu-b-4816; AMD: ieu-a-801)
# Without this: MR beta estimation falls back to provisional Tier 3 only.
OPENGWAS_JWT=Bearer eyJ...

# NCBI E-utilities — free key, register at https://www.ncbi.nlm.nih.gov/account/
# Used for: gene alias resolution, literature cross-reference
# Without this: rate-limited to 3 req/s instead of 10 req/s (slower but functional)
NCBI_API_KEY=your_ncbi_key_here

# Crossref "Polite Pool" — no key needed, just your email
# Without this: anonymous pool (lower rate limits, occasional 429s)
CROSSREF_MAILTO=your@institution.edu

# Semantic Scholar — optional, raises rate limits (https://www.semanticscholar.org/product/api)
# SEMANTIC_SCHOLAR_API_KEY=

# BioGRID — optional, protein interaction data (free at https://thebiogrid.org/account)
# BIOGRID_API_KEY=

# FDA openFDA — optional, adverse events (free at https://open.fda.gov/apis/authentication/)
# FDA_API_KEY=

# === PIPELINE FLAGS ===
# Skip heavy Open Targets disease→target GraphQL; seed genes from L2G only (see docs/RUNTIME.md)
# OPEN_TARGETS_ASSOC_DISABLED=1

# Optional: local Bin-Chen-Lab GPS clone for mcp_servers/gps_server.py only (Tier 4 uses pipelines/gps_disease_screen.py)
# GPS_REPO_PATH=/path/to/GPS

# Agent dispatch: local = no Claude; sdk = Anthropic for selected agents (pi_orchestrator_v2 does not use this)
# AGENT_MODE=local

# === DATA PATHS ===
GRAPH_DB_PATH=./data/graph.kuzu
PERTURB_SEQ_DIR=./data/perturb_seq          # Replogle 2022 GEO GSE246756 h5ad files (~50GB)
VIRAL_REF_DIR=./data/viral_refs
CHIP_CALLS_DIR=./data/chip_calls

# === OPTIONAL: RESTRICTED BIOBANK (apply in parallel, not a prerequisite) ===
# UKB_RAP_TOKEN=
# AOU_WORKSPACE_TOKEN=

# === OPTIONAL: LOCAL MODEL SERVING ===
# TXGEMMA_ENDPOINT=http://localhost:8080
