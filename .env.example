# =============================================================================
# causal-graph-engine v0.2.3 — environment variables
# Copy this file to .env and fill in your credentials.
# The pipeline runs without any keys set; each key unlocks additional evidence.
# =============================================================================

# --- STRONGLY RECOMMENDED (free, <5 min to obtain) --------------------------

# IEU Open GWAS — JWT token (free; register at https://api.opengwas.io via GitHub OAuth)
# Required for: MR instrument lookup (CAD: ieu-a-7 / ieu-b-4816; RA: ieu-a-833)
# Without this: MR beta estimation falls back to provisional Tier 3 only.
# Note: tokens expire after 14 days — renew before each run.
OPENGWAS_JWT=Bearer <paste-your-jwt-here>

# NCBI E-utilities — free key at https://www.ncbi.nlm.nih.gov/account/
# Without this: rate-limited to 3 req/s instead of 10 req/s (slower but functional)
NCBI_API_KEY=

# Crossref "Polite Pool" — just your email, no registration required
# Without this: anonymous pool with lower rate limits
CROSSREF_MAILTO=your@institution.edu

# --- OPTIONAL: AGENT_MODE=sdk -----------------------------------------------

# Anthropic API — only needed when running AGENT_MODE=sdk
# Default mode (AGENT_MODE=local) runs as a pure function-call chain with no API cost
# ANTHROPIC_API_KEY=sk-ant-...

# --- PIPELINE FLAGS (uncomment to enable) ------------------------------------

# Skip heavy Open Targets disease→target GraphQL; seed genes from L2G only
# Speeds up runs significantly; some Tier 2 genes may be missed
# OPEN_TARGETS_ASSOC_DISABLED=1

# Skip non-essential Tier 4 metrics (speeds up debugging runs by ~30%)
# MINIMAL_TIER4=1

# --- DATA PATHS (override defaults if needed) --------------------------------

# Graph DB path — override for tests only; production uses per-disease graph_{slug}.kuzu
# GRAPH_DB_PATH=./data/graph_test.kuzu

# Perturb-seq h5ad files (default: ./data/replogle2022/; ~500 MB each)
# PERTURBSEQ_DATA_DIR=./data/replogle2022

# Static lookup tables: pLI, shet (default: ./data/static/)
# STATIC_DATA_DIR=./data/static
